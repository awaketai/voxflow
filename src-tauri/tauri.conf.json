{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxFlow",
  "version": "0.1.0",
  "identifier": "com.voxflow.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoxFlow Settings",
        "width": 400,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "VoxFlow - Voice to Text"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "VoxFlow.entitlements"
    }
  }
}
